        android:layout_alignParentBottom="true"
        android:layout_marginStart="120dp"
        android:layout_marginTop="158dp"
        android:layout_marginEnd="111dp"
        android:layout_marginBottom="499dp"
        android:text="Lantern" />

    <Button
